@{
    ViewData["Title"] = "Admin Dashboard";
}

<h2><i class="bi bi-shield-lock" style="color: var(--theme-primary);"></i> Admin Dashboard</h2>
<hr />

<div class="row g-4">
    <div class="col-md-3">
        <div class="card stat-card shadow">
            <div class="card-body text-center">
                <i class="bi bi-grid-3x3-gap-fill display-4 stat-icon"></i>
                <h5 class="mt-2 stat-label">Categories</h5>
                <a asp-controller="Categories" asp-action="Index" class="btn btn-primary btn-sm mt-2">Manage</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card shadow">
            <div class="card-body text-center">
                <i class="bi bi-people-fill display-4 stat-icon"></i>
                <h5 class="mt-2 stat-label">Users</h5>
                <a asp-controller="Users" asp-action="Index" class="btn btn-primary btn-sm mt-2">Manage</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card shadow">
            <div class="card-body text-center">
                <i class="bi bi-tag-fill display-4 stat-icon"></i>
                <h5 class="mt-2 stat-label">Offers</h5>
                <a asp-controller="Offers" asp-action="Index" class="btn btn-primary btn-sm mt-2">Review</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card shadow">
            <div class="card-body text-center">
                <i class="bi bi-gear-fill display-4 stat-icon"></i>
                <h5 class="mt-2 stat-label">Settings</h5>
                <a asp-controller="SystemSettings" asp-action="Index" class="btn btn-primary btn-sm mt-2">Manage</a>
            </div>
        </div>
    </div>
</div>

