@model PagedResult<SystemSettings>
@{
    ViewData["Title"] = "System Settings";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-gear-fill"></i> System Settings</h2>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> New Setting</a>
</div>


<table class="table table-striped table-hover shadow-sm">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Key</th>
            <th>Value</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var setting in Model.Items)
        {
            <tr>
                <td>@setting.Id</td>
                <td><code>@setting.Key</code></td>
                <td>@setting.SettingValue</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@setting.Id" class="btn btn-sm btn-outline-warning">
                        <i class="bi bi-pencil"></i> Edit
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>

<partial name="_PagerPartial" model="Model" />

