@model PagedResult<OfferDetailsDto>
@{
    ViewData["Title"] = "Manage Offers";
}

<h2><i class="bi bi-tag-fill"></i> Manage Offers</h2>
<hr />


<table class="table table-striped table-hover table-themed shadow-sm">
    <thead>
        <tr>
            <th>ID</th>
            <th>Title</th>
            <th>Original Price</th>
            <th>Discounted Price</th>
            <th>Status</th>
            <th>Seller</th>
            <th>Created</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var offer in Model.Items.OrderBy(o => o.Status))
        {
            <tr>
                <td>@offer.Id</td>
                <td>@offer.Title</td>
                <td>@offer.OriginalPrice.ToString("C")</td>
                <td>@offer.DiscountedPrice.ToString("C")</td>
                <td>
                    @{
                        var badgeClass = offer.Status switch
                        {
                            "Pending" => "bg-warning text-dark",
                            "Approved" => "bg-success",
                            "Rejected" => "bg-danger",
                            "Expired" => "bg-secondary",
                            "Disabled" => "bg-dark",
                            _ => "bg-info"
                        };
                    }
                    <span class="badge @badgeClass">@offer.Status</span>
                </td>
                <td>@offer.SellerUserName</td>
                <td>@offer.CreatedAt.ToString("yyyy-MM-dd")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@offer.Id" class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-eye"></i>
                    </a>
                    @if (offer.Status == "Pending")
                    {
                        <form asp-action="Approve" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="offerId" value="@offer.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-success">
                                <i class="bi bi-check-lg"></i> Approve
                            </button>
                        </form>
                        <a asp-action="Reject" asp-route-id="@offer.Id" class="btn btn-sm btn-outline-danger">
                            <i class="bi bi-x-lg"></i> Reject
                        </a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

<partial name="_PagerPartial" model="Model" />

