@model PagedResult<UserDto>
@{
    ViewData["Title"] = "Users";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-people-fill"></i> Users</h2>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-person-plus"></i> New User</a>
</div>


<table class="table table-striped table-hover table-themed shadow-sm">
    <thead>
        <tr>
            <th>ID</th>
            <th>Username</th>
            <th>Email</th>
            <th>Role</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model.Items)
        {
            <tr>
                <td>@user.Id</td>
                <td>@user.UserName</td>
                <td>@user.Email</td>
                <td>
                    @{
                        var roleBadge = user.Role switch
                        {
                            "Admin" => "bg-primary",
                            "Seller" => "bg-info text-dark",
                            "Customer" => "bg-success",
                            "Blocked" => "bg-danger",
                            _ => "bg-secondary"
                        };
                    }
                    <span class="badge @roleBadge">@user.Role</span>
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-outline-warning">
                        <i class="bi bi-pencil"></i> Edit
                    </a>
                    @if (user.Role != "Blocked")
                    {
                        <form asp-action="Block" method="post" class="d-inline"
                              onsubmit="return confirm('Are you sure you want to block this user?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="userId" value="@user.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-slash-circle"></i> Block
                            </button>
                        </form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

<partial name="_PagerPartial" model="Model" />

