@model PagedResult<Category>
@{
    ViewData["Title"] = "Categories";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-grid-3x3-gap-fill"></i> Categories</h2>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> New Category</a>
</div>


<table class="table table-striped table-hover table-themed shadow-sm">
    <thead>
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Description</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var cat in Model.Items)
        {
            <tr>
                <td>@cat.Id</td>
                <td>@cat.Name</td>
                <td>@(cat.Description ?? "—")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@cat.Id" class="btn btn-sm btn-outline-warning">
                        <i class="bi bi-pencil"></i> Edit
                    </a>
                    <form asp-action="Delete" method="post" class="d-inline"
                          onsubmit="return confirm('Are you sure you want to delete this category?');">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="categoryId" value="@cat.Id" />
                        <button type="submit" class="btn btn-sm btn-outline-danger">
                            <i class="bi bi-trash"></i> Delete
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

<partial name="_PagerPartial" model="Model" />

