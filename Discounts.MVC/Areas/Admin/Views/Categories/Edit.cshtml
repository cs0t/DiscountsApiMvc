@model EditCategoryViewModel
@{
    ViewData["Title"] = "Edit Category";
}

<h2><i class="bi bi-pencil"></i> Edit Category</h2>
<hr />

<div class="row">
    <div class="col-md-6">
        <div asp-validation-summary="All" class="text-danger mb-3"></div>
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <div class="mb-3">
                <label asp-for="NewName" class="form-label"></label>
                <input asp-for="NewName" class="form-control" />
                <span asp-validation-for="NewName" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="NewDescription" class="form-label"></label>
                <textarea asp-for="NewDescription" class="form-control" rows="3"></textarea>
                <span asp-validation-for="NewDescription" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-warning"><i class="bi bi-check-lg"></i> Update</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

