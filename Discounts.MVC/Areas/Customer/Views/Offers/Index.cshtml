@model PagedResult<OfferDetailsDto>
@{
    ViewData["Title"] = "Browse Offers";
    var filter = ViewBag.Filter as OfferBrowseViewModel;
}

<h2><i class="bi bi-cart"></i> Browse Offers</h2>
<hr />

@* Filter Form *@
<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form method="get" asp-action="Index">
            <div class="row g-3 align-items-end">
                <div class="col-md-2">
                    <label class="form-label">Min Price</label>
                    <input type="number" step="0.01" name="PriceStart" value="@filter?.PriceStart" class="form-control" placeholder="Min" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Max Price</label>
                    <input type="number" step="0.01" name="PriceEnd" value="@filter?.PriceEnd" class="form-control" placeholder="Max" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Categories</label>
                    <select name="CategoryIds" class="form-select" multiple>
                        @if (filter?.AvailableCategories != null)
                        {
                            @foreach (var cat in filter.AvailableCategories)
                            {
                                <option value="@cat.Value" selected="@(filter.CategoryIds?.Contains(int.Parse(cat.Value)) == true)">@cat.Text</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100"><i class="bi bi-search"></i> Filter</button>
                </div>
                <div class="col-md-2">
                    <a asp-action="Index" class="btn btn-outline-secondary w-100">Clear</a>
                </div>
            </div>
        </form>
    </div>
</div>

@if (!Model.Items.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No offers found matching your criteria.
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var offer in Model.Items)
        {
            <div class="col-md-4">
                <div class="card shadow-sm h-100">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@offer.Title</h5>
                        <p class="text-muted small">@(offer.Description ?? "No description")</p>
                        <div class="mt-auto">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="text-decoration-line-through text-muted">@offer.OriginalPrice.ToString("C")</span>
                                <span class="fs-5 fw-bold text-success">@offer.DiscountedPrice.ToString("C")</span>
                            </div>
                            <p class="small text-muted mb-1">
                                <i class="bi bi-clock"></i> Expires: @offer.ExpirationDate.ToString("yyyy-MM-dd")
                            </p>
                            <p class="small text-muted mb-2">
                                <i class="bi bi-box"></i> Remaining:
                                @if (offer.RemainingQuantity > 0)
                                {
                                    <span class="text-success fw-bold">@offer.RemainingQuantity</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Sold Out</span>
                                }
                            </p>
                            @if (offer.Categories.Any())
                            {
                                <div class="mb-2">
                                    @foreach (var cat in offer.Categories)
                                    {
                                        <span class="badge badge-theme me-1">@cat</span>
                                    }
                                </div>
                            }
                            <a asp-action="Details" asp-route-id="@offer.Id" class="btn btn-outline-primary btn-sm w-100">
                                <i class="bi bi-eye"></i> View Details
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @* Pagination *@
    @if (Model.TotalCount > Model.PageSize)
    {
        <nav class="mt-4">
            <ul class="pagination justify-content-center">
                @if (Model.HasPrevious)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="Index"
                           asp-route-PageNumber="@(Model.PageNumber - 1)"
                           asp-route-PriceStart="@filter?.PriceStart"
                           asp-route-PriceEnd="@filter?.PriceEnd">Previous</a>
                    </li>
                }
                @{
                    var totalPages = (int)Math.Ceiling((double)Model.TotalCount / Model.PageSize);
                }
                @for (var i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                        <a class="page-link" asp-action="Index"
                           asp-route-PageNumber="@i"
                           asp-route-PriceStart="@filter?.PriceStart"
                           asp-route-PriceEnd="@filter?.PriceEnd">@i</a>
                    </li>
                }
                @if (Model.HasNext)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="Index"
                           asp-route-PageNumber="@(Model.PageNumber + 1)"
                           asp-route-PriceStart="@filter?.PriceStart"
                           asp-route-PriceEnd="@filter?.PriceEnd">Next</a>
                    </li>
                }
            </ul>
        </nav>
    }
}
