@model SellerDashboardStats
@{
    ViewData["Title"] = "Seller Dashboard";
}

<h2><i class="bi bi-shop"></i> Seller Dashboard</h2>
<hr />

<div class="row g-4">
    <div class="col-md-4">
        <div class="card bg-primary text-white shadow">
            <div class="card-body text-center">
                <i class="bi bi-collection display-4"></i>
                <h3 class="mt-2">@Model.TotalOffers</h3>
                <p>Total Offers</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-success text-white shadow">
            <div class="card-body text-center">
                <i class="bi bi-check-circle display-4"></i>
                <h3 class="mt-2">@Model.ApprovedOffers</h3>
                <p>Approved Offers</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-warning text-dark shadow">
            <div class="card-body text-center">
                <i class="bi bi-hourglass-split display-4"></i>
                <h3 class="mt-2">@Model.PendingOffers</h3>
                <p>Pending Offers</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-secondary text-white shadow">
            <div class="card-body text-center">
                <i class="bi bi-clock-history display-4"></i>
                <h3 class="mt-2">@Model.ExpiredOffers</h3>
                <p>Expired Offers</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-info text-white shadow">
            <div class="card-body text-center">
                <i class="bi bi-ticket-perforated display-4"></i>
                <h3 class="mt-2">@Model.TotalCouponsSold</h3>
                <p>Coupons Sold</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-dark text-white shadow">
            <div class="card-body text-center">
                <i class="bi bi-currency-dollar display-4"></i>
                <h3 class="mt-2">@Model.TotalIncome.ToString("C")</h3>
                <p>Total Income</p>
            </div>
        </div>
    </div>
</div>

<div class="mt-4">
    <a asp-controller="Offers" asp-action="Index" class="btn btn-primary me-2">
        <i class="bi bi-tag"></i> My Offers
    </a>
    <a asp-controller="Offers" asp-action="Create" class="btn btn-success me-2">
        <i class="bi bi-plus-lg"></i> New Offer
    </a>
    <a asp-controller="Sales" asp-action="Index" class="btn btn-info">
        <i class="bi bi-receipt"></i> Sales History
    </a>
</div>

