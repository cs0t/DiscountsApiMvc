@model PagedResult<Offer>
@{
    ViewData["Title"] = "My Offers";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-tag"></i> My Offers</h2>
    <a asp-action="Create" class="btn btn-success"><i class="bi bi-plus-lg"></i> New Offer</a>
</div>

<table class="table table-striped table-hover shadow-sm">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Title</th>
            <th>Original Price</th>
            <th>Discounted Price</th>
            <th>Remaining</th>
            <th>Status</th>
            <th>Expires</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var offer in Model.Items)
        {
            <tr>
                <td>@offer.Id</td>
                <td>@offer.Title</td>
                <td>@offer.OriginalPrice.ToString("C")</td>
                <td>@offer.DiscountedPrice.ToString("C")</td>
                <td>@offer.RemainingQuantity / @offer.MaxQuantity</td>
                <td>
                    @{
                        var statusName = offer.Status?.Name ?? "N/A";
                        var badgeClass = statusName switch
                        {
                            "Pending" => "bg-warning text-dark",
                            "Approved" => "bg-success",
                            "Rejected" => "bg-danger",
                            "Expired" => "bg-secondary",
                            "Disabled" => "bg-dark",
                            _ => "bg-info"
                        };
                    }
                    <span class="badge @badgeClass">@statusName</span>
                </td>
                <td>@offer.ExpirationDate.ToString("yyyy-MM-dd")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@offer.Id" class="btn btn-sm btn-outline-info">
                        <i class="bi bi-eye"></i>
                    </a>
                    <a asp-action="Edit" asp-route-id="@offer.Id" class="btn btn-sm btn-outline-warning">
                        <i class="bi bi-pencil"></i>
                    </a>
                    @if (offer.Status?.Name != "Disabled")
                    {
                        <form asp-action="Disable" method="post" class="d-inline"
                              onsubmit="return confirm('Are you sure you want to disable this offer?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="offerId" value="@offer.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-slash-circle"></i>
                            </button>
                        </form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@* Pagination *@
@if (Model.TotalCount > Model.PageSize)
{
    <nav>
        <ul class="pagination justify-content-center">
            @if (Model.HasPrevious)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Index" asp-route-page="@(Model.PageNumber - 1)">Previous</a>
                </li>
            }
            @{
                var totalPages = (int)Math.Ceiling((double)Model.TotalCount / Model.PageSize);
            }
            @for (var i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@i">@i</a>
                </li>
            }
            @if (Model.HasNext)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Index" asp-route-page="@(Model.PageNumber + 1)">Next</a>
                </li>
            }
        </ul>
    </nav>
}

